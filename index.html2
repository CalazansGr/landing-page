<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,">
<meta name="theme-color" content="#080E17"><meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="Professor particular de matemática online. Aulas personalizadas com o Método Greco — baseado em neurociência para alunos do Ensino Fundamental II.">
<meta name="keywords" content="professor particular matemática online, aulas matemática, reforço escolar, método greco, matemática fundamental">
<meta name="author" content="Guilherme Greco">
<meta name="robots" content="index, follow">

<!-- Open Graph (WhatsApp, Facebook, LinkedIn) -->
<meta property="og:title" content="Método Greco – Matemática que Transforma">
<meta property="og:description" content="Seu filho não é ruim em matemática. Ele só não aprendeu do jeito que o cérebro aprende de verdade. Marque a aula experimental.">
<meta property="og:type" content="website">
<meta property="og:locale" content="pt_BR">

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content="Método Greco – Matemática que Transforma">
<meta name="twitter:description" content="Aulas de matemática baseadas em neurociência. Marque sua aula experimental.">

<!-- Canonical -->
<link rel="canonical" href="https://metodograeco.com.br/">
<title>Método Greco – Matemática que Transforma</title>
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
@font-face {
  font-display: swap;
  font-family: 'Astralaga';
  src: url('data:font/truetype;base64,') format('truetype');
  font-weight: bold; font-style: normal;
}
:root {
  --deep-navy: #0F1A2B; --midnight: #1C2E4A; --dusty: #52677D;
  --ocean: #5B88B2; --pearl: #FBF9E4; --gold: #C9A84C;
  --gold-light: #E8C96A; --gold-glow: rgba(201,168,76,0.35); --s2:#142235; --s3:#1C2E4A; --gold-border:rgba(201,168,76,0.18); --steel:rgba(91,136,178,0.12);
}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
html{background:#080E17;scroll-behavior:smooth;-webkit-text-size-adjust:100%;}body{font-family:'Montserrat',sans-serif;background:radial-gradient(ellipse at 30% 50%, #1A2535 0%, #0D0D0D 70%);color:#F5F5F5;overflow-x:hidden}
::-webkit-scrollbar{width:5px}
::-webkit-scrollbar-track{background:var(--deep-navy)}
::-webkit-scrollbar-thumb{background:var(--gold);border-radius:3px}

/* ── WA FLOAT ── */
#wa-float{touch-action:manipulation;position:fixed;bottom:28px;right:28px;z-index:9999;opacity:0;transform:scale(0.6) translateY(20px);transition:all .5s cubic-bezier(.34,1.56,.64,1);pointer-events:none}
#wa-float.show{opacity:1;transform:scale(1) translateY(0);pointer-events:all}
#wa-float a{display:flex;align-items:center;gap:10px;background:#25D366;color:#fff;padding:12px 20px;border-radius:50px;text-decoration:none;font-weight:700;font-size:.82rem;box-shadow:0 8px 32px rgba(37,211,102,.4);transition:all .3s ease}
#wa-float a:hover{background:#1fb855;box-shadow:0 8px 48px rgba(37,211,102,.7),0 0 0 3px var(--gold-glow);transform:scale(1.05)}

/* ── HERO ── */
#hero{min-height:100vh;background:transparent;position:sticky;top:0;overflow:clip;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 24px 60px}
#hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 900px 600px at 50% 110%,rgba(201,168,76,.10) 0%,transparent 65%);pointer-events:none}
#hero::after{content:'';position:absolute;top:-20%;left:50%;transform:translateX(-50%);width:800px;height:600px;background:radial-gradient(ellipse 700px 500px at 50% 50%,rgba(91,136,178,.07) 0%,transparent 65%);pointer-events:none}
.hero-nav{position:absolute;top:0;left:0;right:0;display:flex;align-items:center;justify-content:space-between;padding:22px 48px;z-index:10}
.logo-text{font-family:'Astralaga',serif;font-size:1.4rem;color:var(--pearl);letter-spacing:.08em}
.logo-text span{color:var(--gold)}
.logo-svg-wrap{height:48px;width:48px;flex-shrink:0}
.hero-content{position:relative;z-index:5;text-align:center;max-width:760px}
.hero-badge{display:inline-flex;align-items:center;gap:8px;background:rgba(201,168,76,.12);border:1px solid rgba(201,168,76,.35);color:var(--gold-light);padding:8px 20px;border-radius:100px;font-size:.72rem;font-weight:600;letter-spacing:.12em;text-transform:uppercase;margin-bottom:32px;animation:fadeSlideDown .8s ease both}
.pain-pills{display:flex;gap:14px;justify-content:center;flex-wrap:wrap;margin-bottom:36px;animation:fadeSlideDown .8s ease both}
.pain-pill{display:inline-flex;align-items:center;gap:8px;background:rgba(201,168,76,.1);border:1px solid rgba(201,168,76,.3);color:var(--gold-light);padding:10px 22px;border-radius:100px;font-size:.75rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase}
.pain-pill-1{animation:breathe 3.8s ease-in-out infinite}
.pain-pill-2{animation:breathe 3.8s ease-in-out infinite;animation-delay:1.9s}
@keyframes breathe{0%,100%{transform:translateY(0);box-shadow:0 0 0 rgba(201,168,76,0)}50%{transform:translateY(-6px);box-shadow:0 8px 28px rgba(201,168,76,.18)}}
.hero-headline{font-family:'Montserrat',sans-serif;font-size:clamp(1.9rem,4vw,3.4rem);color:var(--pearl);line-height:1.18;margin-bottom:28px;font-weight:900;letter-spacing:-0.025em;animation:fadeSlideUp .9s .2s ease both;text-align:center}
/* hook — grande, dourado, brilha */
.hl-hook{font-family:'Astralaga',serif;background:linear-gradient(90deg,var(--gold) 0%,var(--gold-light) 65%,#fff 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;filter:drop-shadow(0 0 18px rgba(201,168,76,.6)) drop-shadow(0 0 40px rgba(201,168,76,.28));font-size:1.08em}
.hl-punct{color:var(--gold-light);opacity:.7}
/* "2 meses" — pílula dourada */
.hl-time{font-style:normal;display:inline-block;background:linear-gradient(135deg,rgba(201,168,76,.22),rgba(201,168,76,.10));border:1.5px solid rgba(201,168,76,.5);border-radius:8px;padding:0 10px 2px;color:var(--gold-light);font-weight:900;font-size:.95em;box-shadow:0 0 18px rgba(201,168,76,.25),inset 0 0 12px rgba(201,168,76,.06);letter-spacing:-.01em;vertical-align:baseline;line-height:1.3}
/* linha inferior — menor, recuada */
.hl-lower{font-size:.7em;font-weight:600;color:rgba(251,249,228,.85);letter-spacing:0;display:block;margin-top:4px}
/* "impossível" — riscado com cor vermelha suave, indicando que não é mais */
.hl-impossible{position:relative;color:rgba(251,249,228,.70)}
.hl-impossible::after{content:'';position:absolute;left:0;right:0;top:50%;height:2px;background:linear-gradient(90deg,transparent,rgba(220,80,80,.75) 20%,rgba(220,80,80,.75) 80%,transparent);transform:translateY(-50%);border-radius:2px}
.hero-sub{font-size:1.05rem;color:rgba(251,249,228,.88);max-width:520px;margin:0 auto 44px;line-height:1.75;animation:fadeSlideUp 1s .35s ease both;text-shadow:0 1px 2px rgba(0,0,0,.3)}
.btn-wa{margin-top:28px;display:inline-flex;align-items:center;gap:12px;background:linear-gradient(135deg,#25D366,#1aab52);color:#fff;text-decoration:none;padding:17px 34px;border-radius:50px;font-weight:700;font-size:.95rem;box-shadow:0 12px 40px rgba(37,211,102,.35);transition:all .3s ease;animation:fadeSlideUp 1s .5s ease both;position:relative}
.btn-wa:hover{transform:translateY(-3px) scale(1.03);box-shadow:0 16px 60px rgba(37,211,102,.5),0 0 40px var(--gold-glow)}

/* floating cards */
.stats-strip{display:flex;flex-wrap:wrap;gap:12px;justify-content:center;padding:32px 24px 40px;background:transparent;border:none;position:relative;overflow:hidden;margin-bottom:-1px}.stats-strip::before{content:'';position:absolute;inset:0;background:transparent;pointer-events:none}.stats-strip .fc{position:relative;z-index:1}
.fc{background:linear-gradient(135deg,rgba(28,46,74,.98),rgba(35,55,85,.95));border:1px solid rgba(91,136,178,.18);border-top:3px solid var(--gold);border-radius:0 0 12px 12px;padding:10px 16px;color:var(--pearl);display:flex;align-items:center;gap:10px;animation:float 5s ease-in-out infinite;backdrop-filter:blur(8px);box-shadow:0 8px 24px rgba(0,0,0,.4),0 2px 8px rgba(201,168,76,.15)}
.fc:nth-child(2){animation-delay:-1.2s}
.fc:nth-child(3){animation-delay:-2.5s}
.fc:nth-child(4){animation-delay:-3.7s}
.fc-icon{font-size:1.1rem;flex-shrink:0}
.fc-label{font-weight:700;font-size:.62rem;color:var(--gold);text-transform:uppercase;letter-spacing:.1em;line-height:1}
.fc-value{font-size:.82rem;font-weight:600;margin-top:2px;line-height:1.2}

/* scroll reveal */
.reveal{opacity:0;transform:translateY(32px) scale(.98);transition:opacity .65s cubic-bezier(.16,1,.3,1),transform .65s cubic-bezier(.16,1,.3,1)}
.reveal.visible{opacity:1;transform:translateY(0) scale(1)}
.reveal-delay-1{transition-delay:.1s}.reveal-delay-2{transition-delay:.2s}
.reveal-delay-3{transition-delay:.3s}.reveal-delay-4{transition-delay:.4s}

section{padding:110px 24px}section:not(#hero){position:relative;z-index:2;background:#0F1A2B;contain:paint}
@media(max-width:768px){section{padding:80px 28px}.eco-list{grid-template-columns:1fr}}
.section-label{display:inline-block;font-size:.68rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:14px}
.section-title{font-family:'Astralaga',serif;font-weight:400;font-size:clamp(1.7rem,4vw,2.9rem);line-height:1.15;margin-bottom:18px}
.section-sub{font-size:.97rem;line-height:1.75;color:rgba(251,249,228,.88);max-width:600px;text-shadow:0 1px 2px rgba(0,0,0,.3)}
.container{max-width:1120px;margin:0 auto}

/* ── DEPOIMENTOS ── */
#depoimentos{background:var(--s2,#142235);position:relative;overflow:hidden}
#depoimentos::before{content:'';position:absolute;inset:0;background:transparent}
#depoimentos .section-title{color:var(--pearl)}
#depoimentos .section-sub{color:rgba(251,249,228,.85)}
.testi-grid{margin-top:52px;display:flex;flex-direction:column;gap:28px}
.testi-row{display:grid;gap:32px}
.testi-row--videos{grid-template-columns:repeat(3,1fr)}
.testi-row--reviews{grid-template-columns:repeat(3,1fr)}
@media(max-width:860px){.testi-row--videos,.testi-row--reviews{grid-template-columns:1fr;gap:28px}}

/* YouTube facade: thumbnail + play button, no iframe until click */
.testi-card{background:linear-gradient(135deg,rgba(28,46,74,.95),rgba(28,46,74,.88));border:1px solid rgba(91,136,178,.45);border-radius:16px;overflow:hidden;transition:all .4s ease;cursor:pointer;box-shadow:0 4px 20px rgba(0,0,0,.3),inset 0 1px 0 rgba(91,136,178,.15);will-change:transform;transform:translateZ(0)}
.testi-card:hover{transform:translateY(-6px);border-color:var(--gold);box-shadow:0 0 0 2px var(--gold-glow),0 20px 60px rgba(0,0,0,.4),0 0 40px var(--gold-glow)}
.yt-facade{position:relative;padding-bottom:48%;height:0;overflow:hidden;background:#0a0a0a;cursor:pointer}
.yt-facade img{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;transition:transform .4s ease,opacity .35s ease;filter:brightness(.92)}
.yt-facade:hover img{opacity:.75;transform:scale(1.04)}
.yt-play{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:48px;height:48px;background:rgba(220,0,0,.93);border-radius:50%;display:flex;align-items:center;justify-content:center;transition:all .35s cubic-bezier(.34,1.56,.64,1);pointer-events:none;box-shadow:0 4px 28px rgba(0,0,0,.6)}
.yt-play::after{content:'';border-style:solid;border-width:9px 0 9px 16px;border-color:transparent transparent transparent #fff;margin-left:4px}
.yt-facade:hover .yt-play{background:rgba(220,0,0,1);transform:translate(-50%,-50%) scale(1.18);box-shadow:0 8px 48px rgba(220,0,0,.55),0 0 36px var(--gold-glow)}
.yt-label{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,.7));padding:24px 12px 8px;color:#fff;font-size:.68rem;font-weight:600;display:flex;align-items:center;gap:5px}
/* ── MODAL ── */


.yt-modal-backdrop{position:absolute;inset:0;background:rgba(5,10,20,.88);backdrop-filter:blur(6px);cursor:pointer}
.yt-modal-box{position:relative;z-index:1;width:min(860px,95vw);background:var(--midnight);border-radius:18px;overflow:hidden;border:1px solid rgba(201,168,76,.25);box-shadow:0 32px 100px rgba(0,0,0,.7),0 0 0 1px rgba(201,168,76,.1);transform:scale(.92) translateY(20px);transition:transform .35s cubic-bezier(.34,1.2,.64,1)}
#yt-modal.open .yt-modal-box{transform:scale(1) translateY(0)}
.yt-modal-header{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid rgba(91,136,178,.15)}
.yt-modal-title{font-weight:700;font-size:.9rem;color:var(--pearl)}
.yt-modal-sub{font-size:.72rem;color:rgba(251,249,228,.68);margin-top:2px}
.yt-modal-close{width:36px;height:36px;border-radius:50%;background:rgba(91,136,178,.12);border:1px solid rgba(91,136,178,.35);color:var(--pearl);font-size:1.2rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .25s;flex-shrink:0;line-height:1}
.yt-modal-close:hover{background:rgba(220,0,0,.2);border-color:rgba(220,0,0,.4);color:#fff}
.yt-modal-player{position:relative;padding-bottom:56.25%;height:0;background:#000;border-radius:0 0 18px 18px;overflow:hidden}
.yt-modal-player iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:none}
.yt-error-box{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px;padding:32px;text-align:center;background:var(--deep-navy)}
.yt-error-box p{color:rgba(251,249,228,.85);font-size:.88rem;line-height:1.6;max-width:400px}
.yt-open-btn{display:inline-flex;align-items:center;gap:10px;background:#FF0000;color:#fff;text-decoration:none;padding:12px 24px;border-radius:50px;font-weight:700;font-size:.88rem;transition:all .3s}
.yt-open-btn:hover{background:#cc0000;transform:scale(1.05)}
.testi-html{background:#080E17;scroll-behavior:smooth;-webkit-text-size-adjust:100%;}body{padding:8px 14px 12px}
.testi-body{padding:14px 16px;text-align:center}.testi-name{font-weight:700;font-size:.82rem;color:var(--gold);margin-bottom:2px}
.testi-role{font-size:.70rem;color:rgba(251,249,228,.75)}

/* Google cards */
.google-card{background:linear-gradient(135deg,rgba(28,46,74,.95),rgba(28,46,74,.88));border:1px solid rgba(91,136,178,.45);border-radius:18px;padding:24px;transition:all .4s ease;box-shadow:0 4px 20px rgba(0,0,0,.3),inset 0 1px 0 rgba(91,136,178,.15)}
.google-card:hover{transform:translateY(-6px);border-color:var(--gold);box-shadow:0 0 0 2px var(--gold-glow),0 20px 60px rgba(0,0,0,.4),0 0 40px var(--gold-glow)}
.g-header{display:flex;align-items:center;gap:12px;margin-bottom:14px}
.g-avatar{width:42px;height:42px;border-radius:50%;background:linear-gradient(135deg,var(--ocean),var(--dusty));display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.95rem;color:#fff;flex-shrink:0}
.g-name{font-weight:700;color:var(--pearl);font-size:.88rem}
.g-date{font-size:.7rem;color:rgba(251,249,228,.65);margin-top:2px}
.g-stars{color:#FBBC04;font-size:.82rem;letter-spacing:2px;margin-bottom:10px}
.g-text{color:rgba(251,249,228,.90);font-size:.86rem;line-height:1.7;text-shadow:0 1px 2px rgba(0,0,0,.2)}
.g-google{display:flex;align-items:center;gap:6px;margin-top:14px;font-size:.7rem;color:rgba(251,249,228,.55)}

/* Google Reviews CTA Card */
.google-cta-card{
  position:relative;
  background:linear-gradient(135deg,rgba(28,46,74,.95) 0%,rgba(28,46,74,.75) 100%);
  border:2px solid rgba(201,168,76,.35);
  border-radius:20px;
  padding:36px 32px;
  text-align:center;
  transition:all .5s cubic-bezier(.34,1.56,.64,1);
  cursor:pointer;
  box-shadow:0 8px 32px rgba(0,0,0,.3),0 0 48px rgba(201,168,76,.12),inset 0 1px 0 rgba(251,249,228,.05);
  overflow:hidden;
  backdrop-filter:blur(12px);
  text-decoration:none;
  display:block;
  max-width:680px;
  margin:0 auto;
  will-change:transform;
  transform:translateZ(0)
}
.google-cta-card::before{
  content:'';
  position:absolute;
  top:0;
  left:0;
  right:0;
  height:3px;
  background:linear-gradient(90deg,transparent 0%,var(--gold) 50%,transparent 100%);
  opacity:0;
  transition:opacity .5s ease
}
.google-cta-card::after{
  content:'';
  position:absolute;
  inset:0;
  background:radial-gradient(circle at 50% 50%,rgba(201,168,76,.08) 0%,transparent 70%);
  opacity:0;
  transition:opacity .5s ease
}
.google-cta-card:hover{
  transform:translateY(-8px) scale(1.02);
  border-color:rgba(201,168,76,.65);
  box-shadow:0 16px 64px rgba(0,0,0,.4),0 0 80px rgba(201,168,76,.25),inset 0 2px 0 rgba(251,249,228,.08)
}
.google-cta-card:hover::before,.google-cta-card:hover::after{opacity:1}

.google-cta-icon{
  display:inline-flex;
  align-items:center;
  justify-content:center;
  width:64px;
  height:64px;
  border-radius:50%;
  background:linear-gradient(135deg,#4285F4 0%,#34A853 35%,#FBBC04 65%,#EA4335 100%);
  margin:0 auto 20px;
  box-shadow:0 8px 32px rgba(66,133,244,.4),0 0 48px rgba(66,133,244,.2);
  transition:all .5s cubic-bezier(.34,1.56,.64,1);
  position:relative
}
.google-cta-icon::after{
  content:'';
  position:absolute;
  inset:-4px;
  border-radius:50%;
  background:inherit;
  filter:blur(12px);
  opacity:.5;
  z-index:-1
}
.google-cta-card:hover .google-cta-icon{
  transform:scale(1.1) rotate(5deg);
  box-shadow:0 12px 48px rgba(66,133,244,.6),0 0 72px rgba(66,133,244,.4)
}
.google-cta-icon svg{
  width:34px;
  height:34px;
  filter:drop-shadow(0 2px 8px rgba(0,0,0,.3))
}

.google-cta-stars{
  display:flex;
  align-items:center;
  justify-content:center;
  gap:4px;
  margin-bottom:14px
}
.google-cta-stars span{
  font-size:1.6rem;
  color:#FBBC04;
  text-shadow:0 0 20px rgba(251,188,4,.6),0 4px 12px rgba(0,0,0,.4);
  animation:starPulse 2s ease-in-out infinite
}
.google-cta-stars span:nth-child(1){animation-delay:0s}
.google-cta-stars span:nth-child(2){animation-delay:.1s}
.google-cta-stars span:nth-child(3){animation-delay:.2s}
.google-cta-stars span:nth-child(4){animation-delay:.3s}
.google-cta-stars span:nth-child(5){animation-delay:.4s}

@keyframes starPulse{
  0%,100%{transform:scale(1);opacity:1}
  50%{transform:scale(1.15);opacity:.9}
}

.google-cta-title{
  font-family:'Montserrat',sans-serif;
  font-weight:800;
  font-size:1.35rem;
  color:var(--pearl);
  margin-bottom:10px;
  line-height:1.2
}
.google-cta-subtitle{
  font-size:.90rem;
  color:rgba(251,249,228,.75);
  margin-bottom:24px;
  line-height:1.5
}
.google-cta-btn{
  touch-action:manipulation;
  display:inline-flex;
  align-items:center;
  gap:10px;
  background:var(--gold);
  color:#0d1a2a;
  padding:14px 28px;
  border-radius:50px;
  font-weight:800;
  font-size:.90rem;
  text-transform:uppercase;
  letter-spacing:.05em;
  transition:all .4s cubic-bezier(.34,1.56,.64,1);
  box-shadow:0 8px 24px rgba(201,168,76,.4),0 0 32px rgba(201,168,76,.2);
  position:relative;
  overflow:hidden
}
.google-cta-btn::before{
  content:'';
  position:absolute;
  top:50%;
  left:50%;
  transform:translate(-50%,-50%) scale(0);
  width:300%;
  height:300%;
  background:radial-gradient(circle,rgba(255,255,255,.3) 0%,transparent 60%);
  transition:transform .6s ease
}
.google-cta-card:hover .google-cta-btn{
  transform:scale(1.05);
  box-shadow:0 12px 36px rgba(201,168,76,.6),0 0 64px rgba(201,168,76,.4)
}
.google-cta-card:hover .google-cta-btn::before{
  transform:translate(-50%,-50%) scale(1)
}
.google-cta-btn svg{
  width:18px;
  height:18px;
  transition:transform .3s ease
}
.google-cta-card:hover .google-cta-btn svg{
  transform:translateX(4px)
}

@media(max-width:768px){
  .google-cta-card{padding:32px 24px;border-radius:18px}
  .google-cta-icon{width:56px;height:56px}
  .google-cta-icon svg{width:30px;height:30px}
  .google-cta-stars span{font-size:1.4rem}
  .google-cta-title{font-size:1.2rem}
  .google-cta-subtitle{font-size:.85rem}
  .google-cta-btn{padding:13px 24px;font-size:.85rem}
}

/* ── GRADUATION PHOTO ── */
#alunos{background:#0F1A2B;padding:0;overflow:hidden}
.alunos-inner{position:relative;height:clamp(320px,50vw,600px);overflow:hidden}
.alunos-inner img{width:100%;height:100%;object-fit:cover;object-position:center 42%;display:block;filter:brightness(.88) contrast(1.05)}
.alunos-overlay{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(15,26,43,.1) 0%,rgba(15,26,43,.7) 100%);display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:48px 24px}
.alunos-caption{text-align:center;color:var(--pearl)}
.alunos-caption h3{font-family:'Montserrat',sans-serif;font-weight:800;font-size:clamp(1.4rem,3vw,2.2rem);margin-bottom:10px}
.alunos-caption p{font-size:.9rem;color:rgba(251,249,228,.90);max-width:500px;text-shadow:0 2px 4px rgba(0,0,0,.4)}

/* ── PROFESSOR ── */
#sobre{background:linear-gradient(160deg,#0F1A2B 0%,#111f30 100%);position:relative;overflow:hidden;z-index:2;border-radius:28px 28px 0 0;margin-top:-80px}
.prof-layout{display:grid;grid-template-columns:1fr 400px;gap:72px;align-items:center;max-width:1100px;margin:0 auto}
.prof-label-row{display:flex;align-items:center;gap:10px;margin-bottom:12px}
.prof-line{display:block;width:28px;height:1.5px;background:var(--ocean);flex-shrink:0}
.prof-label-text{font-size:.7rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(251,249,228,.70)}
.prof-title{font-family:'Montserrat',sans-serif;font-size:clamp(2rem,4vw,3.2rem);font-weight:800;color:var(--pearl);line-height:1.1;margin-bottom:8px}
.prof-em{font-style:italic;color:var(--ocean);filter:drop-shadow(0 0 10px rgba(91,136,178,.7)) drop-shadow(0 0 24px rgba(91,136,178,.4))}
.prof-name{font-family:'Montserrat',sans-serif;font-size:.72rem;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:rgba(251,249,228,.70);margin-bottom:22px}
.prof-bio{color:rgba(251,249,228,.90);font-size:.9rem;line-height:1.75;margin-bottom:12px;text-shadow:0 1px 2px rgba(0,0,0,.2)}
.prof-chips{display:flex;flex-direction:column;gap:10px;margin-top:28px;align-items:flex-start}
.prof-chip{display:inline-flex;align-items:center;gap:10px;background:rgba(28,46,74,0.9);border:1px solid rgba(91,136,178,.3);border-radius:100px;padding:10px 18px;font-size:.82rem;color:var(--pearl);font-weight:600;transition:all .3s;border-color:rgba(201,168,76,.40);box-shadow:0 0 14px rgba(201,168,76,.25),0 0 36px rgba(201,168,76,.12),inset 0 0 10px rgba(201,168,76,.06)}
.prof-chip:hover{border-color:rgba(201,168,76,.65)!important;box-shadow:0 0 22px rgba(201,168,76,.40),0 0 52px rgba(201,168,76,.20)!important}
.prof-chip:hover{border-color:rgba(91,136,178,.7);background:rgba(40,65,105,0.95)}
.chip-icon{display:inline-flex;align-items:center;justify-content:center;flex-shrink:0;width:22px;height:22px;color:var(--gold)}
.prof-photo-wrap{position:relative}
.prof-photo-frame{position:relative;border-radius:12px;overflow:hidden;border:1px solid rgba(91,136,178,.35)}
.prof-photo-frame img{width:100%;display:block;object-fit:cover;max-height:560px;object-position:top center;filter:brightness(.95) contrast(1.05)}
.pf-corner{position:absolute;width:28px;height:28px;z-index:10}
.pf-tl{top:10px;left:10px;border-top:2px solid var(--ocean);border-left:2px solid var(--ocean)}
.pf-tr{top:10px;right:10px;border-top:2px solid var(--ocean);border-right:2px solid var(--ocean)}
.pf-bl{bottom:10px;left:10px;border-bottom:2px solid var(--ocean);border-left:2px solid var(--ocean)}
.pf-br{bottom:10px;right:10px;border-bottom:2px solid var(--ocean);border-right:2px solid var(--ocean)}

/* ── CTA ── */
#cta{background:#0F1A2B;text-align:center;position:relative;overflow:hidden}
#cta::before{content:'';position:absolute;inset:0;background:transparent}
#cta::after{content:'';position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:700px;height:400px;background:transparent;pointer-events:none}
.cta-inner{position:relative;z-index:5}
#cta .section-title{color:var(--pearl);max-width:680px;margin:0 auto 14px}
#cta .section-sub{color:rgba(251,249,228,.85);margin:0 auto 44px;text-shadow:0 1px 2px rgba(0,0,0,.3)}
.pdf-book-wrap{perspective:1400px;display:flex;justify-content:center;margin-bottom:36px}
.pdf-book{
  width:260px;height:360px;
  transform-style:preserve-3d;
  cursor:default;
  transition:transform .1s linear;
  position:relative;
}
.pdf-book img{width:100%;height:100%;object-fit:cover;border-radius:8px;display:block}
.pdf-book-glow{
  position:absolute;inset:-4px;border-radius:12px;
  background:transparent;
  transition:box-shadow .4s ease;
  pointer-events:none;
}
.spin-aura .pdf-book-glow{box-shadow:0 0 0 3px var(--gold),0 0 60px rgba(201,168,76,.6),0 0 120px rgba(201,168,76,.3)}
.btn-cta{display:inline-flex;align-items:center;gap:14px;background:linear-gradient(135deg,var(--gold) 0%,#a8882a 100%);color:var(--deep-navy);text-decoration:none;padding:18px 42px;border-radius:50px;font-weight:800;font-size:.95rem;letter-spacing:.02em;box-shadow:0 12px 40px rgba(201,168,76,.4);transition:all .35s ease}
.btn-cta:hover{transform:translateY(-4px) scale(1.04);box-shadow:0 20px 70px rgba(201,168,76,.6),0 0 60px var(--gold-glow)}

/* ── FOOTER ── */
footer{background:#070d15;padding:36px 24px;text-align:center;border-top:1px solid rgba(91,136,178,.1);position:relative;z-index:2}
.footer-logo{font-family:'Astralaga',serif;font-size:1.2rem;color:var(--pearl);margin-bottom:10px}
.footer-logo span{color:var(--gold)}
footer p{font-size:.76rem;color:rgba(251,249,228,.50)}

/* ── KEYFRAMES ── */
@keyframes fadeSlideDown{from{opacity:0;transform:translateY(-20px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeSlideUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
@keyframes float{0%,100%{transform:translateY(0) rotate(-1deg)}50%{transform:translateY(-14px) rotate(1deg)}}

/* ── RESPONSIVE ── */
@media(max-width:900px){
  .prof-layout{grid-template-columns:1fr;gap:40px}
  .prof-photo-wrap{order:-1;max-width:360px;margin:0 auto}
}
@media(max-width:700px){
  .hero-nav{padding:18px 20px}
  .logo-text{font-size:1rem}
  .stats-strip{gap:8px;padding:20px 16px}
  .fc{padding:8px 12px}
}

/* ── SCARCITY BAR ── */
#scarcity-bar{
  position:fixed;top:0;left:0;right:0;z-index:10000;
  background:rgba(26,37,53,.95);
  border-bottom:2px solid rgba(220,40,40,.4);
  padding:0 20px;
  display:flex;align-items:center;justify-content:center;gap:10px;
  max-height:0;overflow:hidden;
  transition:max-height .6s cubic-bezier(.34,1.2,.64,1),padding .5s ease;
  box-shadow:0 2px 16px rgba(0,0,0,.15);
}
#scarcity-bar.visible{max-height:52px;padding-top:12px;padding-bottom:12px}
@media(min-width:768px){
  #scarcity-bar.visible{max-height:56px}
  .sc-text{font-size:.95rem}
}
.sc-dot{width:8px;height:8px;border-radius:50%;background:#e02020;flex-shrink:0;animation:sc-pulse 1.4s ease-in-out infinite}
@keyframes sc-pulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(.65)}}
.sc-close{margin-left:14px;width:22px;height:22px;border-radius:50%;background:rgba(251,249,228,.08);border:1px solid rgba(251,249,228,.15);color:rgba(251,249,228,.85);font-size:.8rem;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s;line-height:1}
.sc-close:hover{background:rgba(220,40,40,.1);border-color:rgba(220,40,40,.3);color:#e02020}


/* ── PROMISES ── */
#promessas{background:linear-gradient(180deg,#0F1A2B 0%,#111c2d 100%);padding:90px 24px;overflow:hidden}
.promises-header{text-align:center;margin-bottom:64px}
.promises-header .section-title{color:var(--pearl)}
.promises-header .section-sub{color:rgba(251,249,228,.75);margin:14px auto 0;max-width:540px}

/* ── LISTA DE ITENS DO ECOSSISTEMA ── */
.eco-list{display:grid;grid-template-columns:repeat(2,1fr);gap:20px;max-width:1040px;margin:0 auto}.eco-list .eco-item:last-child:nth-child(odd){grid-column:1 / -1;max-width:calc(50% - 10px);margin:0 auto;}

.eco-item{display:grid;grid-template-columns:52px 1fr;gap:0;align-items:stretch;position:relative;transition:all .35s ease;background:var(--s3,#1C2E4A);border:1px solid rgba(91,136,178,0.12);border-radius:16px;padding:24px 24px 24px 16px}

/* linha vertical conectando os itens */
.eco-item:not(:last-child) .eco-line::after{display:none}

.eco-icon-col{
  display:flex;
  flex-direction:column;
  align-items:center;
  padding-top:4px;
  position:relative
}
.eco-icon-col.eco-line{position:relative}

.eco-dot{width:44px;height:44px;border-radius:12px;border:1px solid var(--gold-border,rgba(201,168,76,0.18));background:rgba(201,168,76,0.06);display:flex;align-items:center;justify-content:center;font-size:1.1rem;font-family:'Astralaga',serif;color:var(--gold);flex-shrink:0;transition:all .35s ease;position:relative;z-index:1;letter-spacing:0}
.eco-item:hover{border-color:var(--gold-border,rgba(201,168,76,0.18));box-shadow:0 8px 32px rgba(201,168,76,0.08);transform:translateY(-3px)}.eco-item:hover .eco-dot{
  border-color:var(--gold);
  background:rgba(201,168,76,.1);
  box-shadow:0 0 0 6px rgba(201,168,76,.08)
}

.eco-content{padding:4px 0 0 20px;}
.eco-item:last-child .eco-content{padding-bottom:0}

.eco-label{
  display:inline-block;
  font-size:.62rem;
  font-weight:800;
  letter-spacing:.18em;
  text-transform:uppercase;
  color:var(--gold);
  opacity:.75;
  margin-bottom:6px
}
.eco-title{
  font-family:'Montserrat',sans-serif;
  font-weight:700;
  font-size:1.05rem;
  color:var(--pearl);
  margin-bottom:8px;
  line-height:1.25;
  transition:color .3s ease
}
.eco-item:hover .eco-title{color:#fff}
.eco-desc{
  font-size:.9rem;
  color:rgba(251,249,228,.68);
  line-height:1.7;
  max-width:600px
}
.eco-desc strong{color:rgba(251,249,228,.88);font-weight:600}

/* card final — objetivo */
.eco-goal{
  max-width:820px;
  margin:40px auto 0;
  padding:28px 36px;
  border-radius:16px;
  background:rgba(201,168,76,.06);
  border:1px solid rgba(201,168,76,.2);
  display:flex;
  align-items:center;
  gap:20px
}
.eco-goal-icon{display:inline-flex;align-items:center;flex-shrink:0;color:var(--gold)}
.eco-goal-text{font-size:.92rem;color:rgba(251,249,228,.85);line-height:1.6}
.eco-goal-text strong{color:var(--gold);font-weight:700}

@media(max-width:768px){
  .eco-list .eco-item:last-child:nth-child(odd){grid-column:auto;max-width:none;margin:0}
  .eco-item{grid-template-columns:44px 1fr}
  .eco-dot{width:40px;height:40px;font-size:1.1rem}
  .eco-item:not(:last-child) .eco-line::after{display:none}
  .eco-content{padding:6px 0 32px 20px}
  .eco-title{font-size:.98rem}
  .eco-desc{font-size:.86rem}
  .eco-goal{padding:22px 24px;flex-direction:column;gap:12px;text-align:center}
}

/* ── COMPARISON TABLE ── */
#comparison{position:relative;overflow:hidden;background:var(--s2,#142235)}
.comparison-header{text-align:center;margin-bottom:56px;position:relative;z-index:1}
.comparison-subtitle{font-size:.7rem;font-weight:800;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:16px;display:block}
.comparison-title{font-size:clamp(1.6rem,4.5vw,3rem);line-height:1.2;margin-bottom:0}
.comparison-title .serif{font-family:'Montserrat',sans-serif;font-weight:800;color:var(--pearl);display:inline-block}
.comparison-title .script{font-family:'Montserrat',sans-serif;font-weight:800;font-style:italic;color:var(--gold);text-shadow:0 0 24px var(--gold-glow),0 0 48px rgba(201,168,76,.15);display:inline-block}
.comparison-table-wrap{max-width:900px;margin:0 auto 48px;position:relative;z-index:1;overflow-x:auto;-webkit-overflow-scrolling:touch;scrollbar-width:none;-ms-overflow-style:none}.comparison-table-wrap::-webkit-scrollbar{display:none}
.comparison-table{width:100%;border-collapse:separate;border-spacing:0 12px}
.comparison-table thead th{font-size:.7rem;font-weight:800;letter-spacing:.15em;text-transform:uppercase;padding:14px 20px;text-align:center;color:rgba(251,249,228,.70);border-bottom:1px solid rgba(201,168,76,.15)}
.comparison-table thead th:first-child{text-align:left;color:var(--gold)}.comparison-table thead th:nth-child(2){color:var(--gold);border-bottom:2px solid var(--gold)}.comparison-table tbody td:nth-child(2){background:rgba(201,168,76,0.04)}
.comparison-table tbody tr{background:rgba(28,46,74,.35);transition:all .3s ease}
.comparison-table tbody tr:hover{background:rgba(28,46,74,.55);transform:translateY(-2px)}
.comparison-table tbody td{padding:20px;font-size:.88rem;border-top:1px solid rgba(91,136,178,.08);border-bottom:1px solid rgba(91,136,178,.08)}
.comparison-table tbody td:first-child{border-left:1px solid rgba(91,136,178,.08);border-top-left-radius:8px;border-bottom-left-radius:8px;color:#FFF;font-weight:500}
.comparison-table tbody td:last-child{border-right:1px solid rgba(91,136,178,.08);border-top-right-radius:8px;border-bottom-right-radius:8px}
.comparison-table tbody td:nth-child(2),.comparison-table tbody td:nth-child(3){text-align:center;font-size:1.5rem}
.check-icon{display:inline-flex;align-items:center;justify-content:center}
.cross-icon{display:inline-flex;align-items:center;justify-content:center}
.comparison-cta{text-align:center;position:relative;z-index:1}
.comparison-btn{display:inline-flex;align-items:center;justify-content:center;gap:14px;background:#25D366;color:#000;padding:18px 42px;border-radius:50px;text-decoration:none;font-weight:800;font-size:.95rem;text-transform:uppercase;letter-spacing:.08em;box-shadow:0 8px 32px rgba(37,211,102,.5),0 0 64px rgba(37,211,102,.25);transition:all .4s cubic-bezier(.34,1.56,.64,1);position:relative;overflow:hidden}
.comparison-btn::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:radial-gradient(circle,rgba(255,255,255,.2) 0%,transparent 70%);opacity:0;transition:opacity .4s ease}
.comparison-btn:hover{background:#1fb855;transform:translateY(-4px) scale(1.05);box-shadow:0 12px 48px rgba(37,211,102,.7),0 0 96px rgba(37,211,102,.35),0 0 0 4px var(--gold-glow)}
.comparison-btn:hover::before{opacity:1}
.comparison-btn svg{width:24px;height:24px;fill:currentColor}
@media(max-width:768px){
.comparison-table{font-size:.8rem}
.comparison-table thead th,.comparison-table tbody td{padding:12px 10px}
.comparison-table tbody td:nth-child(2),.comparison-table tbody td:nth-child(3){font-size:1.2rem}
.comparison-btn{padding:16px 32px;font-size:.85rem}
}

/* ── FAQ ── */
#faq{background:#0F1A2B;position:relative;overflow:hidden;padding:120px 24px}
#faq::before{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background:radial-gradient(circle at 30% 20%,rgba(201,168,76,.03) 0%,transparent 50%),radial-gradient(circle at 70% 80%,rgba(91,136,178,.04) 0%,transparent 50%);pointer-events:none;z-index:0}

.faq-header{text-align:center;max-width:820px;margin:0 auto 64px;position:relative;z-index:1}
.faq-header::before{
  content:'';
  position:absolute;
  top:-80px;
  left:50%;
  transform:translateX(-50%);
  width:120px;
  height:120px;
  background:radial-gradient(circle,rgba(201,168,76,.15) 0%,transparent 70%);
  border-radius:50%;
  animation:pulseGlow 3s ease-in-out infinite
}
.faq-header h2{
  font-family:'Montserrat',sans-serif;
  font-weight:700;
  font-size:clamp(1.6rem,4vw,2.5rem);
  line-height:1.35;
  margin-bottom:0;
  position:relative;
  padding-bottom:24px
}
.faq-header h2::after{
  content:'';
  position:absolute;
  bottom:0;
  left:50%;
  transform:translateX(-50%);
  width:80px;
  height:3px;
  background:linear-gradient(90deg,transparent 0%,var(--gold) 50%,transparent 100%);
  box-shadow:0 0 20px var(--gold-glow)
}
.faq-header h2 .faq-line1{
  display:block;
  color:var(--gold);
  font-weight:800;
  letter-spacing:.02em;
  text-shadow:0 0 30px rgba(201,168,76,.6),0 0 60px rgba(201,168,76,.3),0 4px 12px rgba(0,0,0,.4);
  animation:shimmer 4s ease-in-out infinite
}
.faq-header h2 .faq-line2{
  display:block;
  margin-top:8px;
  color:rgba(251,249,228,.88);
  font-weight:600;
  text-shadow:0 2px 8px rgba(0,0,0,.4)
}
.faq-header h2 .faq-line3{
  display:block;
  margin-top:12px;
  background:linear-gradient(135deg,var(--ocean) 0%,var(--dusty) 50%,var(--gold) 100%);
  -webkit-background-clip:text;
  -webkit-text-fill-color:transparent;
  background-clip:text;
  font-weight:700;
  background-size:200% 200%;
  animation:gradientShift 5s ease infinite;
  text-shadow:none;
  filter:drop-shadow(0 2px 8px rgba(91,136,178,.4))
}

@keyframes shimmer{
  0%,100%{text-shadow:0 0 30px rgba(201,168,76,.6),0 0 60px rgba(201,168,76,.3),0 4px 12px rgba(0,0,0,.4)}
  50%{text-shadow:0 0 40px rgba(201,168,76,.8),0 0 80px rgba(201,168,76,.5),0 4px 16px rgba(0,0,0,.5)}
}

@keyframes gradientShift{
  0%{background-position:0% 50%}
  50%{background-position:100% 50%}
  100%{background-position:0% 50%}
}

@keyframes pulseGlow{
  0%,100%{opacity:.4;transform:translateX(-50%) scale(1)}
  50%{opacity:.7;transform:translateX(-50%) scale(1.2)}
}

.faq-list{max-width:880px;margin:0 auto;position:relative;z-index:1}

.faq-item{
  position:relative;
  background:linear-gradient(135deg,rgba(28,46,74,.45) 0%,rgba(28,46,74,.30) 100%);
  border:1px solid rgba(91,136,178,.15);
  border-radius:16px;
  margin-bottom:28px;
  overflow:hidden;
  transition:all .5s cubic-bezier(.34,1.56,.64,1);
  backdrop-filter:blur(8px);
  box-shadow:0 4px 12px rgba(0,0,0,.1),inset 0 1px 0 rgba(251,249,228,.03)
}
.faq-item::before{
  content:'';
  position:absolute;
  top:0;
  left:0;
  right:0;
  height:2px;
  background:linear-gradient(90deg,transparent 0%,var(--gold) 50%,transparent 100%);
  opacity:0;
  transition:opacity .5s ease
}
.faq-item:hover{
  border-color:rgba(201,168,76,.35);
  background:linear-gradient(135deg,rgba(28,46,74,.55) 0%,rgba(28,46,74,.40) 100%);
  transform:translateY(-3px);
  box-shadow:0 8px 24px rgba(0,0,0,.2),0 0 48px rgba(201,168,76,.08),inset 0 1px 0 rgba(251,249,228,.05)
}
.faq-item:hover::before{opacity:1}

.faq-item.open{
  border-color:rgba(201,168,76,.45);
  background:linear-gradient(135deg,rgba(28,46,74,.60) 0%,rgba(28,46,74,.45) 100%);
  box-shadow:0 12px 32px rgba(0,0,0,.25),0 0 64px rgba(201,168,76,.12),inset 0 1px 0 rgba(251,249,228,.06)
}
.faq-item.open::before{opacity:1}

.faq-question{
  width:100%;
  padding:28px 32px;
  display:flex;
  justify-content:space-between;
  align-items:center;
  gap:24px;
  background:none;
  border:none;
  color:var(--pearl);
  font-family:'Montserrat',sans-serif;
  font-size:1.06rem;
  font-weight:600;
  text-align:left;
  cursor:pointer;
  transition:all .3s ease;
  position:relative;
  z-index:1
}
.faq-question span:first-child{
  flex:1;
  transition:color .3s ease,transform .3s ease
}
.faq-question:hover span:first-child{
  color:var(--gold);
  transform:translateX(4px)
}

.faq-plus{
  width:40px;
  height:40px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:1.8rem;
  font-weight:300;
  color:var(--gold);
  background:rgba(201,168,76,.08);
  border-radius:50%;
  transition:all .5s cubic-bezier(.34,1.56,.64,1);
  flex-shrink:0;
  line-height:1;
  box-shadow:0 0 0 0 rgba(201,168,76,.3)
}
.faq-question:hover .faq-plus{
  background:rgba(201,168,76,.15);
  transform:scale(1.1);
  box-shadow:0 0 0 8px rgba(201,168,76,.1),0 4px 12px rgba(201,168,76,.3)
}
.faq-item.open .faq-plus{
  transform:rotate(45deg) scale(1.05);
  background:var(--gold);
  color:#0d1a2a;
  box-shadow:0 0 0 12px rgba(201,168,76,.15),0 6px 20px rgba(201,168,76,.5),0 0 32px rgba(201,168,76,.3)
}

.faq-answer{
  max-height:0;
  overflow:hidden;
  transition:max-height .6s cubic-bezier(.34,1.56,.64,1),padding .6s cubic-bezier(.34,1.56,.64,1),opacity .4s ease;
  opacity:0
}
.faq-item.open .faq-answer{
  max-height:1000px;
  padding:0 32px 32px 32px;
  opacity:1
}
.faq-answer::before{
  content:'';
  display:block;
  width:60px;
  height:3px;
  background:linear-gradient(90deg,var(--gold) 0%,transparent 100%);
  margin-bottom:20px;
  opacity:0;
  transform:translateX(-20px);
  transition:all .5s ease .2s
}
.faq-item.open .faq-answer::before{
  opacity:1;
  transform:translateX(0)
}
.faq-answer p{
  font-size:.95rem;
  line-height:1.8;
  color:rgba(251,249,228,.85);
  margin:0;
  text-shadow:0 1px 2px rgba(0,0,0,.2);
  transform:translateY(10px);
  transition:transform .5s ease .1s
}
.faq-item.open .faq-answer p{transform:translateY(0)}

@media(max-width:768px){
  #faq{background:#0F1A2B;padding:80px 28px}
  .faq-header{margin-bottom:48px;padding:0 0}
  .faq-header h2{font-size:clamp(1.4rem,5vw,2rem)}
  .faq-list{padding:0 0}
  .faq-item{margin-bottom:20px;border-radius:12px}
  .faq-question{padding:26px 26px;font-size:.96rem;gap:20px}
  .faq-plus{width:36px;height:36px;font-size:1.5rem}
  .faq-item.open .faq-answer{padding:0 26px 28px 26px}
  .faq-answer p{font-size:.90rem;line-height:1.75}
  .faq-answer::before{width:40px;margin-bottom:16px}
}

/* ── REBRANDING v26 ADDITIONS ── */

/* Section dividers: thin gold line between key sections */
#depoimentos::after { content:''; display:block; position:absolute; bottom:0; left:50%; transform:translateX(-50%); width:60px; height:2px; background:var(--gold); opacity:0.4; }

/* Eco grid: single column on small mobile */
@media(max-width:480px){ .eco-list{grid-template-columns:1fr} }

/* Eco item card: last item full width if odd count */
@media(min-width:769px){ .eco-item:last-child:nth-child(odd){grid-column:span 1;max-width:500px;margin:0 auto;justify-self:center} }

/* Eco dot number animation */
.eco-item:hover .eco-dot { background:rgba(201,168,76,0.12); border-color:var(--gold); color:var(--gold-light); }

/* Prof photo frame: gold accent */
.prof-photo-frame { border:1px solid rgba(91,136,178,.25) !important; }
.prof-photo-frame::after { content:''; position:absolute; inset:0; border-radius:12px; box-shadow:inset 0 0 0 2px rgba(201,168,76,0.15); pointer-events:none; }

/* Comparison: Greco column header badge */
.comparison-table thead th:nth-child(2)::before { content:'★ '; color:var(--gold); }

/* Stats strip: tighter for premium look */
.stats-strip .fc { border-top-color: var(--gold) !important; }

/* Section titles: improve line-height for serif */
.section-title { line-height:1.1; letter-spacing:-0.01em; }

/* Depoimentos testimonial cards: gold top accent */
.testi-card { border-top: 2px solid rgba(201,168,76,0.3) !important; }
.video-card { border-top: 2px solid rgba(201,168,76,0.3) !important; }

/* FAQ icon: animated on open */
.faq-icon { transition: transform 0.3s ease; }
.faq-item.open .faq-icon { transform: rotate(45deg); }

/* Footer: gold separator */
footer::before, .site-footer::before { content:''; display:block; width:100%; height:1px; background:linear-gradient(90deg,transparent,var(--gold),transparent); margin-bottom:32px; opacity:0.3; }

/* ── STACKING CARDS — DEPOIMENTOS ── */
/* Desktop: subtle depth on cards being covered */
.testi-row--videos {
  perspective: 1200px;
}
.testi-row--videos .testi-card {
  transform-origin: center bottom;
  transition: transform 0.5s cubic-bezier(.16,1,.3,1), opacity 0.5s ease, box-shadow 0.4s ease;
}
.testi-row--videos .testi-card.card-stacked {
  transform: scale(0.96) translateY(-6px);
  opacity: 0.72;
  box-shadow: 0 2px 8px rgba(0,0,0,.5);
}

/* Mobile: TRUE sticky stack — title fixed + cards stack below it */
@media (max-width: 860px) {
  #depoimentos { overflow: visible; }
  #depoimentos .container { overflow: visible; }

  /* Fix 1: titulo fica fixo no topo enquanto o baralho acontece */
  #depoimentos .container > div:first-child {
    position: -webkit-sticky;
    position: sticky;
    top: 16px;
    z-index: 60;
    background: #0F1A2B;
    padding-bottom: 20px;
  }

  .testi-row--videos {
    display: block !important;
  }

  /* Cards empilham ABAIXO do titulo fixo */
  .testi-row--videos .testi-card {
    position: -webkit-sticky;
    position: sticky;
    top: 240px;
    margin-bottom: 90px;
    border-radius: 18px;
    display: block;
    width: 100%;
  }
  .testi-row--videos .testi-card:nth-child(1) { z-index: 10; }
  .testi-row--videos .testi-card:nth-child(2) { z-index: 20; }
  .testi-row--videos .testi-card:nth-child(3) { z-index: 30; }
  .testi-row--videos .testi-card:nth-child(4) { z-index: 40; }
  .testi-row--videos .testi-card:nth-child(5) { z-index: 50; margin-bottom: 300px; }

  /* Fix 2: Google card e a ultima carta do baralho */
  .testi-row--videos .google-cta-card {
    position: relative;
    display: block;
    max-width: none;
    width: 100%;
    margin-top: 32px;
    border-radius: 18px;
    min-height: auto;
    padding: 24px;
  }
}
/* Google card inside testi grid */
.testi-row--videos .google-cta-card {
  max-width: none;
  margin: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}
/* Compact comparison table on mobile */
@media (max-width: 600px) {
  .comparison-table thead th { padding:10px 6px; font-size:.58rem; letter-spacing:.06em; }
  .comparison-table tbody td { padding:14px 6px; font-size:.80rem; }
  .comparison-table tbody td:nth-child(2),
  .comparison-table tbody td:nth-child(3) { font-size:1.2rem; }
  .comparison-table tbody td:first-child { font-size:.78rem; }
}
/* Directional reveal for pillar cards */
.reveal-right {
  opacity:0;
  transform:translateX(40px) scale(.98);
  transition:opacity .65s cubic-bezier(.16,1,.3,1),transform .65s cubic-bezier(.16,1,.3,1);
}
.reveal-left {
  opacity:0;
  transform:translateX(-40px) scale(.98);
  transition:opacity .65s cubic-bezier(.16,1,.3,1),transform .65s cubic-bezier(.16,1,.3,1);
}
.reveal-right.visible,.reveal-left.visible {
  opacity:1;
  transform:translateX(0) scale(1);
}</style>
</head>
