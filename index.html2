<script>
// ── SCROLL REVEAL ──
(function(){
  const selectors=['.section-label','.section-title','.fc-card','.prof-bio','.cred-item','.video-card','.google-cta-card','.eco-item','.comp-row','.faq-item','.cta-block'];
  const staggered=['.fc-card','.eco-item','.video-card','.comp-row','.cred-item','.faq-item'];
  selectors.forEach(function(sel){
    document.querySelectorAll(sel).forEach(function(el,i){
      el.classList.add('reveal');
      if(staggered.indexOf(sel)>-1){
        var d=Math.min(i%4,3);
        if(d>0) el.classList.add('reveal-delay-'+d);
      }
    });
  });
  var obs=new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting) e.target.classList.add('visible'); });
  },{threshold:0.12,rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.reveal').forEach(function(el){ obs.observe(el); });
})();

// ── WA FLOAT ──
const waFloat = document.getElementById('wa-float');
const heroH = document.getElementById('hero').offsetHeight;
window.addEventListener('scroll', () => {
  waFloat.classList.toggle('show', window.scrollY > heroH * 0.55);
}, {passive:true});

// YouTube opens in new tab (embedding disabled by video owner)

// ── PDF BOOK SPIN ──
(function() {
  const book = document.getElementById('pdfBook');
  if (!book) return;
  let cur = 0, tgt = 0, raf = null;
  const section = document.getElementById('cta');
  function getP() {
    const r = section.getBoundingClientRect();
    const wh = window.innerHeight;
    return Math.min(1, Math.max(0, (wh - r.top) / (wh + r.height)));
  }
  function lerp(a,b,t){ return a+(b-a)*t; }
  function anim() {
    cur = lerp(cur, tgt, 0.08);
    book.style.transform = `rotateY(${cur}deg)`;
    if(Math.abs(cur-tgt) > 0.5) raf = requestAnimationFrame(anim);
    else raf = null;
  }
  window.addEventListener('scroll', () => {
    tgt = getP() * 720;
    const inView = getP() > 0.05 && getP() < 0.95;
    book.classList.toggle('spin-aura', inView);
    if(!raf) raf = requestAnimationFrame(anim);
  }, {passive:true});
})();

// ── 3D COVERFLOW ──
(function() {
  const track = document.getElementById('cfTrack');
  if (!track) return;
  const items = Array.from(track.querySelectorAll('.cf-item'));
  const infoIcon = document.getElementById('cfInfoIcon');
  const infoText = document.getElementById('cfInfoText');
  const cfInfo = document.getElementById('cfInfo');
  let active = Math.floor(items.length / 2);
  let startX = null;

  // Build card HTML
  items.forEach(item => {
    item.innerHTML = `
      <div class="cf-emoji">${item.dataset.emoji}</div>
      <div class="cf-title">${item.dataset.title}</div>
      <div class="cf-author">${item.dataset.author}</div>
    `;
    item.addEventListener('click', () => {
      const idx = items.indexOf(item);
      if(idx !== active) goTo(idx);
    });
  });

  function goTo(idx) {
    active = ((idx % items.length) + items.length) % items.length;
    render();
  }

  function render() {
    const n = items.length;
    items.forEach((item, i) => {
      let d = ((i - active + n) % n + n) % n;
      if (d > n/2) d -= n;
      const a = Math.abs(d);
      const angle = d * 40;
      const tx = d * 200;
      const scale = a === 0 ? 1 : a === 1 ? 0.80 : 0.62;
      const opacity = a === 0 ? 1 : a === 1 ? 0.6 : 0.3;
      const tz = -a * 80;
      item.style.transform = `translateX(${tx}px) rotateY(${-angle}deg) scale(${scale}) translateZ(${tz}px)`;
      item.style.opacity = opacity;
      item.style.zIndex = 10 - a;
      item.classList.toggle('active', a === 0);
    });

    const ai = items[active];
    if(infoIcon) infoIcon.textContent = ai.dataset.icon;
    if(infoText) infoText.textContent = ai.dataset.text;
    if(cfInfo) cfInfo.classList.add('visible');
  }

  document.getElementById('cfPrev').addEventListener('click', () => goTo(active - 1));
  document.getElementById('cfNext').addEventListener('click', () => goTo(active + 1));

  // Touch swipe
  track.addEventListener('touchstart', e => { startX = e.touches[0].clientX; }, {passive:true});
  track.addEventListener('touchend', e => {
    if (startX === null) return;
    const dx = e.changedTouches[0].clientX - startX;
    if (Math.abs(dx) > 40) goTo(active + (dx < 0 ? 1 : -1));
    startX = null;
  }, {passive:true});

  // Mouse drag
  let mouseStartX = null;
  track.addEventListener('mousedown', e => { mouseStartX = e.clientX; });
  track.addEventListener('mouseup', e => {
    if(mouseStartX === null) return;
    const dx = e.clientX - mouseStartX;
    if(Math.abs(dx) > 40) goTo(active + (dx < 0 ? 1 : -1));
    mouseStartX = null;
  });

  // Keyboard
  document.addEventListener('keydown', e => {
    if(e.key === 'ArrowLeft') goTo(active - 1);
    if(e.key === 'ArrowRight') goTo(active + 1);
  });

  render();
})();
</script>

<!-- YouTube plays inline in card -->

<script>
// ── INLINE VIDEO — replace thumbnail with iframe inside the card ──
function openYT(facadeEl, vid) {
  const wrap = facadeEl.parentElement; // the relative wrapper
  const iframe = document.createElement('iframe');
  iframe.src = `https://www.youtube.com/embed/${vid}?autoplay=1&rel=0&modestbranding=1&color=white&playsinline=1`;
  iframe.allow = 'accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';
  iframe.allowFullscreen = true;
  iframe.style.cssText = 'position:absolute;top:0;left:0;width:100%;height:100%;border:none';
  facadeEl.innerHTML = '';
  facadeEl.appendChild(iframe);
  facadeEl.style.cursor = 'default';
}

// ── STACKING CARDS ──
(function(){
  if(window.innerWidth > 860) {
    var cards = document.querySelectorAll('.testi-row--videos .testi-card');
    if(!cards.length) return;
    var stackObs = new IntersectionObserver(function(entries){
      entries.forEach(function(e){
        var idx = Array.from(cards).indexOf(e.target);
        if(!e.isIntersecting) {
          // Card scrolled out from top = being stacked under next card
          e.target.classList.add('card-stacked');
        } else {
          e.target.classList.remove('card-stacked');
        }
      });
    }, {threshold: 0.15, rootMargin: '-60px 0px 0px 0px'});
    cards.forEach(function(c){ stackObs.observe(c); });
  }
})();

// Directional reveal — pillar cards
(function(){
  var items = document.querySelectorAll('.eco-item');
  if(!items.length) return;
  items.forEach(function(el, i){
    el.classList.remove('reveal');
    el.classList.add(i % 2 === 0 ? 'reveal-right' : 'reveal-left');
  });
  var obs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if(e.isIntersecting) e.target.classList.add('visible'); });
  }, {threshold:0.15, rootMargin:'0px 0px -40px 0px'});
  document.querySelectorAll('.reveal-right,.reveal-left').forEach(function(el){ obs.observe(el); });
})();

// Mobile: move Google card outside the sticky stack so it stays static
(function(){
  if(window.innerWidth > 860) return;
  var gc = document.querySelector('.testi-row--videos .google-cta-card');
  var row = document.querySelector('.testi-row--videos');
  if(gc && row && row.parentNode) {
    gc.style.marginTop = '32px';
    row.parentNode.insertBefore(gc, row.nextSibling);
  }
})();

</script>
<!-- scarcity JS removido -->
</body>
</html>
